# ─── AI Courtroom v2.0 Environment ────────────────────────────────────────────
# Copy this file to .env and fill in real values.

# PostgreSQL (used in Docker / production)
DATABASE_URL=postgresql+asyncpg://courtroom:courtroom_secret@localhost:5432/courtroom

# Anthropic Claude API key — required for courtroom simulation
ANTHROPIC_API_KEY=your_key_here

# File upload settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Server
PORT=8000
